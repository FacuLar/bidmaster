# Puerto del servidor (Render/Railway inyectan PORT automáticamente)
PORT=4000

# Secreto para firmar los JWT (cambialo en producción)
JWT_SECRET=bidmaster_super_secret_2026
JWT_EXPIRES_IN=7d

# Base de datos:
#  - Si DATABASE_URL existe -> se usa Postgres (producción/online)
#  - Si no existe           -> se usa SQLite local (bidmaster.sqlite)
# DATABASE_URL=postgres://user:pass@host:5432/bidmaster

# URL base del servicio de streaming (no forma parte del desarrollo de la app)
STREAM_BASE_URL=wss://stream.bidmaster.com

# Clave del panel de administración. Las aprobaciones (registros y medios de
# pago) sólo se hacen desde Postman enviando el header  x-admin-key: <ADMIN_KEY>.
ADMIN_KEY=bidmaster_admin_2026

# Verificación de existencia real del email (registros MX del dominio).
#  - true  -> rechaza emails de dominios inexistentes (recomendado)
#  - false -> sólo valida el formato (útil sin acceso a internet/DNS)
VERIFICAR_EMAIL=true

# Verificación de existencia real del domicilio legal (OpenStreetMap/Nominatim).
#  - true  -> geocodifica el domicilio; rechaza calles que no existen
#  - false -> sólo valida el formato (calle + número)
# Si el servicio externo no responde, NO bloquea el registro (fail-open).
VERIFICAR_DOMICILIO=true
