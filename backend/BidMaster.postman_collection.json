                "recuperar-password"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"facundo@ejemplo.com\"\n}"
            },
            "description": "Devuelve codigo_reset (modo demo)."
          }
        },
        {
