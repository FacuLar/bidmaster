              ],
              "path": [
                "auth",
                "resetear-password"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"facundo@ejemplo.com\",\n  \"codigo\": \"123456\",\n  \"password_nueva\": \"nueva123\"\n}"
            }
          }
        }
      ]
    },
