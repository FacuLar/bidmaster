              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postulante.demo@gmail.com\"\n}"
            }
          }
        },
        {
          "name": "Recuperar contraseña",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
